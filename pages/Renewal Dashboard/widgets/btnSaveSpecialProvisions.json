  "needsErrorInfo": false,
  "onClick": "{{\n  !tblRuns.selectedRow.id\n    ? showAlert(\"Select a renewal run first.\", \"warning\")\n    : q_save_special_provisions.run({\n        run_id: tblRuns.selectedRow.id,\n        special_provisions: inpSpecialProvisions.text || null\n      })\n      .then(() => {\n        showAlert(\"Special provisions saved for run \" + tblRuns.selectedRow.id, \"success\");\n        return q_runs.run();\n      })\n      .then(() => q_run.run())\n      .catch((error) => {\n        showAlert(\n          \"Save special provisions failed: \" + JSON.stringify(error),\n          \"error\"\n        );\n      })\n}}",
